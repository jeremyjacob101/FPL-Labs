// class Main

// function Main.main 0 -> void
function Main.main 1
	push constant 8001
	push constant 16
	push constant 1
	neg
	call Main.fillMemory 3
	pop temp 0
	push constant 8000
	call Memory.peek 1
	pop local 0
	push local 0
	call Main.convert 1
	pop temp 0
	push constant 0
	return
	

// function Main.convert 1 -> void
function Main.convert 3
	push constant 1
	neg
	pop local 2
	goto Main.convert$DO_COND_2
	label Main.convert$LOOP_1
	push local 1
	push constant 1
	add
	pop local 1
	push local 0
	call Main.nextMask 1
	pop local 0
	push local 1
	push constant 16
	gt
	not
	not
	if-goto Main.convert$ELSE_4
	push argument 0
	push local 0
	and
	push constant 0
	eq
	not
	not
	if-goto Main.convert$ELSE_6
	push constant 8000
	push local 1
	add
	push constant 1
	call Memory.poke 2
	pop temp 0
	goto Main.convert$IF_AFTER_5
	label Main.convert$ELSE_6
	push constant 8000
	push local 1
	add
	push constant 0
	call Memory.poke 2
	pop temp 0
	label Main.convert$IF_AFTER_5
	goto Main.convert$IF_AFTER_3
	label Main.convert$ELSE_4
	push constant 0
	pop local 2
	label Main.convert$IF_AFTER_3
	label Main.convert$DO_COND_2
	push local 2
	if-goto Main.convert$LOOP_1
	push constant 0
	return
	

// function Main.nextMask 1 -> int
function Main.nextMask 0
	push argument 0
	push constant 0
	eq
	not
	if-goto Main.nextMask$ELSE_8
	push constant 1
	return
	goto Main.nextMask$IF_AFTER_7
	label Main.nextMask$ELSE_8
	push argument 0
	push constant 2
	call Math.multiply 2
	return
	label Main.nextMask$IF_AFTER_7
	

// function Main.fillMemory 3 -> void
function Main.fillMemory 0
	goto Main.fillMemory$DO_COND_10
	label Main.fillMemory$LOOP_9
	push argument 0
	push argument 2
	call Memory.poke 2
	pop temp 0
	push argument 1
	push constant 1
	sub
	pop argument 1
	push argument 0
	push constant 1
	add
	pop argument 0
	label Main.fillMemory$DO_COND_10
	push argument 1
	push constant 0
	gt
	if-goto Main.fillMemory$LOOP_9
